      </div>
      <div class="bar"></div>
      <div class="rblock" style="border-color:var(--plum);background:var(--plum-lt);">
        <div class="rb-note" style="color:var(--plum);">Mi</div><div class="rb-syl">Ta</div>
      </div>
      <div class="rblock" style="border-color:var(--plum);background:var(--plum-lt);">
        <div class="rb-note" style="color:var(--plum);">Mi</div><div class="rb-syl">Ka</div>
      </div>
      <div class="rblock" style="border-color:var(--gold);background:var(--gold-lt);border-width:3px;">
        <div class="rb-note" style="color:var(--gold);font-size:22px;">Ré</div><div class="rb-syl" style="font-size:12px;">Ta !</div>
      </div>
    </div>
 
    <div class="tip green" style="margin-top:16px;">
      <span class="tip-ico">🏆</span>
      <p class="tip-txt"><strong>Você conseguiu!</strong> Esta melodia usa todas as notas aprendidas (Ré, Mi, Fá, Sol, Lá, Si) com células binárias (Ta-Ka) e ternárias (Ta-Ki-Ta), pausas, e dinâmicas. É uma peça de verdade!</p>
    </div>
  </div>
 
  <!-- Reflexão final: Gramani e Konnakol -->
  <div class="card">
    <h3>🌟 O que Aprendemos — Gramani e Konnakol Unidos</h3>
    <svg viewBox="0 0 680 200" width="100%">
      <!-- Two circles, Venn-like -->
      <ellipse cx="220" cy="100" rx="180" ry="80" fill="#FDEADF" stroke="#C8583A" stroke-width="1.5"/>
      <ellipse cx="460" cy="100" rx="180" ry="80" fill="#DCF3EE" stroke="#1D8B7A" stroke-width="1.5"/>
      <!-- Overlap -->
      <ellipse cx="340" cy="100" rx="60" ry="60" fill="#FEF6DC" opacity=".9"/>
 
      <!-- Left: Gramani -->
      <text x="150" y="72" text-anchor="middle" font-family="Baloo 2,sans-serif" font-size="14" font-weight="800" fill="#7A3020">Gramani</text>
      <text x="138" y="94"  text-anchor="middle" font-family="Nunito,sans-serif" font-size="11" font-weight="700" fill="#C8583A">• Pulso corporal</text>
      <text x="138" y="110" text-anchor="middle" font-family="Nunito,sans-serif" font-size="11" font-weight="700" fill="#C8583A">• Peso dos tempos</text>
      <text x="138" y="126" text-anchor="middle" font-family="Nunito,sans-serif" font-size="11" font-weight="700" fill="#C8583A">• Dinâmica natural</text>
      <text x="138" y="142" text-anchor="middle" font-family="Nunito,sans-serif" font-size="11" font-weight="700" fill="#C8583A">• Células rítmicas</text>
 
      <!-- Right: Konnakol -->
      <text x="540" y="72" text-anchor="middle" font-family="Baloo 2,sans-serif" font-size="14" font-weight="800" fill="#0A5044">Konnakol</text>
      <text x="550" y="94"  text-anchor="middle" font-family="Nunito,sans-serif" font-size="11" font-weight="700" fill="#1D8B7A">• Sílabas vocais</text>
      <text x="550" y="110" text-anchor="middle" font-family="Nunito,sans-serif" font-size="11" font-weight="700" fill="#1D8B7A">• Ta Ka Di Mi</text>
      <text x="550" y="126" text-anchor="middle" font-family="Nunito,sans-serif" font-size="11" font-weight="700" fill="#1D8B7A">• Voz = percussão</text>
      <text x="550" y="142" text-anchor="middle" font-family="Nunito,sans-serif" font-size="11" font-weight="700" fill="#1D8B7A">• Memória rítmica</text>
 
      <!-- Center intersection -->
      <text x="340" y="94"  text-anchor="middle" font-family="Baloo 2,sans-serif" font-size="11" font-weight="800" fill="#6A4A08">Sentir o</text>
      <text x="340" y="108" text-anchor="middle" font-family="Baloo 2,sans-serif" font-size="11" font-weight="800" fill="#6A4A08">ritmo por</text>
      <text x="340" y="122" text-anchor="middle" font-family="Baloo 2,sans-serif" font-size="11" font-weight="800" fill="#6A4A08">dentro!</text>
 
      <!-- Result label -->
      <text x="340" y="178" text-anchor="middle" font-family="Baloo 2,sans-serif" font-size="14" font-weight="800" fill="#2A1A0A">= Música viva, respirada e sentida 🎵</text>
    </svg>
  </div>
 
  <!-- Certificate-like card -->
  <div style="border-radius:20px;padding:28px;text-align:center;background:var(--ink);border:1.5px solid rgba(255,200,100,0.2);margin-bottom:20px;">
    <div style="font-family:'Baloo 2',sans-serif;font-size:28px;font-weight:800;color:#FDEADF;margin-bottom:6px;">Parabéns, Musicista!</div>
    <div style="font-size:14px;color:rgba(255,255,255,0.6);margin-bottom:20px;line-height:1.6;">Você completou os 10 módulos do Método Ilustrado de Flauta Doce.<br>Gramani e Konnakol estão dentro de você agora.</div>
    <div style="display:flex;justify-content:center;gap:14px;flex-wrap:wrap;">
      <div style="background:rgba(255,255,255,0.07);border-radius:14px;padding:14px 20px;min-width:100px;">
        <div style="font-family:'Baloo 2',sans-serif;font-size:24px;font-weight:800;color:#E07050;">6</div>
        <div style="font-size:11px;font-weight:700;color:rgba(255,255,255,0.5);margin-top:2px;">notas</div>
      </div>
      <div style="background:rgba(255,255,255,0.07);border-radius:14px;padding:14px 20px;min-width:100px;">
        <div style="font-family:'Baloo 2',sans-serif;font-size:24px;font-weight:800;color:#3DBBAA;">4</div>
        <div style="font-size:11px;font-weight:700;color:rgba(255,255,255,0.5);margin-top:2px;">sílabas Konnakol</div>
      </div>
      <div style="background:rgba(255,255,255,0.07);border-radius:14px;padding:14px 20px;min-width:100px;">
        <div style="font-family:'Baloo 2',sans-serif;font-size:24px;font-weight:800;color:#E0A030;">10</div>
        <div style="font-size:11px;font-weight:700;color:rgba(255,255,255,0.5);margin-top:2px;">módulos</div>
      </div>
      <div style="background:rgba(255,255,255,0.07);border-radius:14px;padding:14px 20px;min-width:100px;">
        <div style="font-family:'Baloo 2',sans-serif;font-size:24px;font-weight:800;color:#B089D4;">1</div>
        <div style="font-size:11px;font-weight:700;color:rgba(255,255,255,0.5);margin-top:2px;">música completa</div>
      </div>
    </div>
  </div>
</div>
 
</div><!-- /content -->
 
<!-- Progress dots -->
<div class="pdots" id="pdots">
  <div class="pdot on"  onclick="show(6,null,0)"></div>
  <div class="pdot"     onclick="show(7,null,1)"></div>
  <div class="pdot"     onclick="show(8,null,2)"></div>
  <div class="pdot"     onclick="show(9,null,3)"></div>
  <div class="pdot"     onclick="show(10,null,4)"></div>
</div>
 
<script>
/* ===== NAV ===== */
let curTab = 6;
function show(n, btn, dotIdx){
  document.querySelectorAll('.section').forEach(s=>s.classList.remove('on'));
  document.querySelectorAll('.ntab').forEach(b=>b.classList.remove('on'));
  document.getElementById('sec'+n).classList.add('on');
  if(btn) btn.classList.add('on');
  else {
    const tabs = document.querySelectorAll('.ntab');
    const idx = n-6;
    if(tabs[idx]) tabs[idx].classList.add('on');
  }
  document.querySelectorAll('.pdot').forEach((d,i)=>{
    d.classList.toggle('on', i===(dotIdx!==undefined?dotIdx:n-6));
  });
  curTab=n;
  window.scrollTo({top:0,behavior:'smooth'});
}
 
/* ===== PAUSE PLAYER (Módulo 7) ===== */
const PAUSE_PATS = [
  [{n:'Sol',c:'gold',s:'Ta'},{n:'Sol',c:'gold',s:'Ka'},{n:'—',c:'rest',s:'shh'},{n:'Lá',c:'teal',s:'Ta'}],
  [{n:'Si',c:'coral',s:'Ta'},{n:'—',c:'rest',s:'shh'},{n:'Lá',c:'teal',s:'Ta'},{n:'—',c:'rest',s:'shh'}],
  [{n:'Sol',c:'gold',s:'Ta'},{n:'Lá',c:'teal',s:'Ki'},{n:'Sol',c:'gold',s:'Ta'},{n:'—',c:'rest',s:'shh'}]
];
let pausePat = 0;
let pauseRunning=false;
let pauseBeat=0;
let pauseTimer=null;
let pauseActx=null;
 
function setPauseEx(i){
  pausePat=i;
  buildPausePat(PAUSE_PATS[i]);
  buildPauseSlots(PAUSE_PATS[i]);
  if(pauseRunning){pauseBeat=0;}
}
 
const colorMap={coral:'var(--coral)',teal:'var(--teal)',gold:'var(--gold)',plum:'var(--plum)',rose:'var(--rose)',rest:'var(--ink3)'};
const bgMap={coral:'var(--coral-lt)',teal:'var(--teal-lt)',gold:'var(--gold-lt)',plum:'var(--plum-lt)',rose:'var(--rose-lt)',rest:'var(--parchment)'};
 
function buildPausePat(pat){
  const c=document.getElementById('pause-pattern');
  if(!c)return;
  c.innerHTML='';
  pat.forEach((p,i)=>{
    const pill=document.createElement('span');
    pill.className='beat-pill';
    pill.id='pp'+i;
    pill.textContent=p.s;
    if(p.c==='rest') pill.classList.add('rest');
    c.appendChild(pill);
  });
}
 
function buildPauseSlots(pat){
  const c=document.getElementById('pause-ex');
  if(!c)return;
  c.innerHTML='';
  pat.forEach(p=>{
    const b=document.createElement('div');
    b.className='rblock';
    b.style.cssText=`border-color:${colorMap[p.c]};background:${bgMap[p.c]};${p.c==='rest'?'opacity:.5':''}`;
    b.innerHTML=`<div class="rb-note" style="color:${colorMap[p.c]}">${p.n}</div><div class="rb-syl">${p.s}</div>`;
    c.appendChild(b);
  });
}
 
function getACtx(){
  if(!pauseActx) pauseActx=new (window.AudioContext||window.webkitAudioContext)();
  return pauseActx;
}
 
function pauseClick(isAccent,when){
  const c=getACtx();
  const g=c.createGain();
  g.connect(c.destination);
  const o=c.createOscillator();
  o.frequency.value=isAccent?700:1100;
  o.connect(g);
  g.gain.setValueAtTime(isAccent?.7:.4,when);
  g.gain.exponentialRampToValueAtTime(0.001,when+.06);
  o.start(when);o.stop(when+.07);
}
 
function togglePausePlayer(){
  if(pauseRunning){stopPP();}else{startPP();}
}
 
function startPP(){
  const c=getACtx();
  if(c.state==='suspended')c.resume();
  pauseRunning=true;pauseBeat=0;
  document.getElementById('pause-play-ico').textContent='⏹';
  document.getElementById('pause-play-txt').textContent='Parar';
  runPP();
}
 
function runPP(){
  if(!pauseRunning)return;
  const pat=PAUSE_PATS[pausePat];
  const b=pauseBeat%pat.length;
  document.querySelectorAll('.beat-pill').forEach((p,i)=>{
    p.classList.remove('hi','lo');
    if(i===b) p.classList.add(b===0?'hi':'lo');
  });
  const p=pat[b];
  if(p.c!=='rest') pauseClick(b===0, getACtx().currentTime);
  pauseBeat++;
  pauseTimer=setTimeout(runPP,60000/72);
}
 
function stopPP(){
  pauseRunning=false;clearTimeout(pauseTimer);
  document.getElementById('pause-play-ico').textContent='▶';
  document.getElementById('pause-play-txt').textContent='Iniciar';
  document.querySelectorAll('.beat-pill').forEach(p=>p.classList.remove('hi','lo'));
}
 
setPauseEx(0);
 
/* ===== CELL BUILDER (Módulo 9) ===== */
const CELLS=[];
const CELL_CLR={coral:'c',teal:'t',gold:'g',purple:'p',rose:'r',rest:'rest'};
const PRESETS=[
  [{s:'Ta',c:'coral'},{s:'Ka',c:'teal'},{s:'Ta',c:'coral'},{s:'shh',c:'rest'}],
  [{s:'Ta',c:'coral'},{s:'Ki',c:'gold'},{s:'Ta',c:'coral'},{s:'Ka',c:'teal'},{s:'Di',c:'purple'},{s:'Mi',c:'rose'}],
  [{s:'Ta',c:'coral'},{s:'Ki',c:'gold'},{s:'Ta',c:'coral'}]
];
 
function addCell(s,c){
  if(CELLS.length>=8)return;
  CELLS.push({s,c});
  renderCells();
}
 
function clearCells(){CELLS.length=0;renderCells();}
 
function renderCells(){
  const wrap=document.getElementById('cell-slots');
  if(!wrap)return;
  if(CELLS.length===0){
    wrap.innerHTML='<span style="font-size:12px;font-weight:700;color:var(--ink3);align-self:center;">↑ adicione sílabas acima</span>';
    document.getElementById('cell-count').textContent='0';
    document.getElementById('cell-bar').style.width='0%';
    return;
  }
  wrap.innerHTML='';
  CELLS.forEach((cell,i)=>{
    const cl=CELL_CLR[cell.c]||'c';
    const s=document.createElement('div');
    s.className=`cell-slot filled ${cl}`;
    s.innerHTML=`<span style="font-family:'Baloo 2',sans-serif;font-size:14px;font-weight:800;">${cell.s}</span>`;
    s.onclick=()=>{CELLS.splice(i,1);renderCells();};
    s.title='Clique para remover';
    wrap.appendChild(s);
  });
  document.getElementById('cell-count').textContent=CELLS.length;
  document.getElementById('cell-bar').style.width=(CELLS.length/8*100)+'%';
}
 
function loadPreset(i){
  CELLS.length=0;
  PRESETS[i].forEach(c=>CELLS.push(c));
  renderCells();
}
 
let cellActx=null;
let cellRunning=false;
let cellBeat=0;
let cellTid=null;
 
function playCells(){
  if(!cellActx) cellActx=new (window.AudioContext||window.webkitAudioContext)();
  if(cellActx.state==='suspended')cellActx.resume();
  if(CELLS.length===0)return;
  if(cellRunning){cellRunning=false;clearTimeout(cellTid);return;}
  cellRunning=true;cellBeat=0;runCells();
}
 
function runCells(){
  if(!cellRunning)return;
  const b=cellBeat%CELLS.length;
  const cell=CELLS[b];
  const slots=document.querySelectorAll('#cell-slots .cell-slot');
  slots.forEach((s,i)=>{s.style.transform=i===b?'scale(1.15)':'scale(1)';});
  if(cell.c!=='rest'){
    const c=cellActx;
    const g=c.createGain();g.connect(c.destination);
    const o=c.createOscillator();
    o.frequency.value=b===0?600:900;
    o.connect(g);
    g.gain.setValueAtTime(b===0?.7:.4,c.currentTime);
    g.gain.exponentialRampToValueAtTime(0.001,c.currentTime+.06);
    o.start(c.currentTime);o.stop(c.currentTime+.07);
  }
  cellBeat++;
  cellTid=setTimeout(runCells,60000/80);
}
 
/* ===== LEARN STEPS (Módulo 10) ===== */
const STEP_HINTS=[
  '1️⃣ Bata o pé no pulso (♩=72). Conte 1-2-3-4 em voz alta. Faça isso por 1 minuto antes de pegar a flauta.',
  '2️⃣ Leia as sílabas Konnakol em voz alta: Ta-Ka, Ta-Ki-Ta, shh. Bata palmas enquanto fala. Não pegue a flauta ainda!',
  '3️⃣ Cante a melodia com "lá-lá-lá" ou com os nomes das notas (Ré, Mi, Fá...). A voz aprende antes dos dedos.',
  '4️⃣ Segure a flauta e faça os dedilhados sem soprar. Apenas mova os dedos nas notas corretas, no ritmo certo.',
  '5️⃣ Agora sim! Toque a música completa com som. Sopre suave, sinta o pulso, e comemore — você fez música!'
];
 
let learnStep=0;
function setLearnStep(i){
  learnStep=i;
  const steps=document.querySelectorAll('#learn-steps .step');
  steps.forEach((s,idx)=>{
    s.classList.toggle('done', idx<=i);
  });
  const hint=document.getElementById('step-hint');
  if(hint) hint.textContent=STEP_HINTS[i];
}
setLearnStep(0);
</script>
</body>
</html>
 
