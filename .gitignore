      </div>
      <div class="rblock" style="border-color:var(--gold);background:var(--gold-lt);">
        <div class="rb-note" style="color:var(--gold);">Sol</div><div class="rb-syl">Ka</div>
      </div>
      <div class="bar"></div>
      <div class="rblock" style="border-color:var(--teal);background:var(--teal-lt);">
        <div class="rb-note" style="color:var(--teal);">Lá</div><div class="rb-syl">Ta</div>
      </div>
      <div class="rblock" style="border-color:var(--teal);background:var(--teal-lt);">
        <div class="rb-note" style="color:var(--teal);">Lá</div><div class="rb-syl">Ka</div>
      </div>
      <div class="rblock" style="border-color:var(--coral);background:var(--coral-lt);">
        <div class="rb-note" style="color:var(--coral);">Si</div><div class="rb-syl">Ta</div>
      </div>
      <div class="rblock" style="border-color:var(--coral);background:var(--coral-lt);">
